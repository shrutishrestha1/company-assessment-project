# Server (5001 avoids macOS AirPlay using port 5000)
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database - MsSQL
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Password123
DB_NAME=remit_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=remit-service
KAFKA_GROUP_ID=remit-consumer-group
KAFKA_TOPIC=transactions

# Any email can sign in; first OTP creates a user (operator or AUTO_PROVISION_ROLE). Disable in production.
AUTO_PROVISION_USERS=false
AUTO_PROVISION_ROLE=operator
#
# Local dev: skip email; fixed OTP (only when NODE_ENV=development). Use false in production.
LOCAL_DEV_DUMMY_AUTH=false
DEV_FIXED_OTP=123456
#
# Email — used when LOCAL_DEV_DUMMY_AUTH=false
# https://myaccount.google.com/apppasswords
OTP_LOG_ONLY=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=RemitApp <your-email@gmail.com>

# OTP
OTP_EXPIRES_MINUTES=5
OTP_LENGTH=6

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5
